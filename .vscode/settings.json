{
  "files.readonlyInclude": { "**/route-tree.gen.ts": true, "generated/**": true },
  "files.watcherExclude": { "**/route-tree.gen.ts": true },
  "search.exclude": { "**/route-tree.gen.ts": true },

  "cssVariables.lookupFiles": ["**/*.css", "node_modules/@mantine/core/styles.css"],

  "oxc.configPath": ".oxlintrc.json",
  "oxc.disableNestedConfig": true,
  "oxc.enable": true,
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.tsConfigPath": "tsconfig.json",

  "prisma.pinToPrisma6": true,

  "[css][html][json][jsonc][markdown][postcss][typescript][typescriptreact][yaml]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
